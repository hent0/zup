--TEST--
std.io.File writes to disk, invalidates on close, and reads back through a []u8 buffer
--FILE--
const std = import("std");

pub fn main(): i32 {
  std.io.stdout().writeln("chained");

  const wf = std.io.open("/tmp/zup_file_test.txt", .Write);
  if wf == null {
    return 1;
  }
  let f: std.io.File = wf!;
  f.writeln("roundtrip");
  f.close();
  if f.isValid() {
    return 2;
  }

  const rf = std.io.open("/tmp/zup_file_test.txt", .Read);
  if rf == null {
    return 4;
  }
  let back: std.io.File = rf!;
  let storage: [4]u8 = [0, 0, 0, 0];
  let buf: []u8 = storage;
  let n: i64 = back.read(buf);
  back.close();
  if n == 4 {
    return storage[0] as i32;
  }
  return 3;
}
--CLEANUP--
rm -f /tmp/zup_file_test.txt
--EXPECT--
chained
--EXIT--
114
