--TEST--
std.io.File writes to disk, invalidates on close, and reads back through a []u8 buffer
--FILE--
const std = import("std");

pub fn main(): i32 {
  std.io.stdout().writeln("chained");

  let f: std.io.File = std.io.File{fd: -1};
  match std.io.open("/tmp/zup_file_test.txt", .Write) {
    .Ok(x) => { f = x; },
    .Err(e) => { return 1; },
  };
  f.writeln("roundtrip");
  match f.close() {
    .Ok(c) => {},
    .Err(e2) => { return 2; },
  };
  match f.close() {
    .Ok(c2) => { return 2; },
    .Err(e3) => {},
  };

  let back: std.io.File = std.io.File{fd: -1};
  match std.io.open("/tmp/zup_file_test.txt", .Read) {
    .Ok(x) => { back = x; },
    .Err(e) => { return 4; },
  };
  let storage: [4]u8 = [0, 0, 0, 0];
  let buf: []u8 = storage;
  let n: i64 = match back.read(buf) {
    .Ok(c) => c,
    .Err(e) => 0,
  };
  back.close();
  if n == 4 {
    return storage[0] as i32;
  }
  return 3;
}
--CLEANUP--
rm -f /tmp/zup_file_test.txt
--EXPECT--
chained
--EXIT--
114
