--TEST--
File.readln returns the first line of the read chunk as a str, without the newline
--PREPARE--
printf 'first line\nsecond\n' > /tmp/zup_readline.txt
--FILE--
const std = import("std");

pub fn main(): i32 {
  let f: std.io.File = std.io.File{fd: -1};
  match std.io.open("/tmp/zup_readline.txt", .Read) {
    .Ok(x) => { f = x; },
    .Err(e) => { return -1; },
  };
  let buf: [32]u8;
  let line: str = match f.readln(buf) {
    .Ok(l) => l,
    .Eof => "",
    .Err(e) => "",
  };
  f.close();
  std.io.println(line);
  return line.len as i32;
}
--CLEANUP--
rm -f /tmp/zup_readline.txt
--EXPECT--
first line
--EXIT--
10
