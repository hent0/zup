--TEST--
the open/defer close idiom: the file handle is released at scope exit and the write lands on disk
--FILE--
const std = import("std");

fn writeIt() {
  let file: std.io.File = std.io.File{fd: -1};
  match std.io.open("/tmp/zup_defer.txt", .Write) {
    .Ok(f) => { file = f; },
    .Err(e) => { return; },
  };
  defer file.close();
  file.writeln("deferred");
}

pub fn main(): i32 {
  writeIt();
  let f: std.io.File = std.io.File{fd: -1};
  match std.io.open("/tmp/zup_defer.txt", .Read) {
    .Ok(x) => { f = x; },
    .Err(e) => { return 1; },
  };
  defer f.close();
  let buf: [16]u8;
  const line = match f.readln(buf) {
    .Ok(l) => l,
    .Eof => "",
    .Err(e) => "",
  };
  std.io.println(line);
  return 0;
}
--CLEANUP--
rm -f /tmp/zup_defer.txt
--EXPECT--
deferred
--EXIT--
0
