--TEST--
std.env reads environment variables as ?str; std.fromCstr views NUL-terminated data without copying
--FILE--
const std = import("std");

pub fn main(): i32 {
  const path = std.env("PATH");
  if path == null {
    return 1;
  }
  const p = path ?? "";
  if p.len == 0 {
    return 2;
  }

  if std.env("ZUP_DEFINITELY_UNSET_VAR_XYZ") != null {
    return 3;
  }

  if std.fromCstr(null) != "" {
    return 4;
  }

  std.io.println("ok");
  return 0;
}
--EXPECT--
ok
--EXIT--
0
