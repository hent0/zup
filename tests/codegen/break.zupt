--TEST--
break inside an if branches to the enclosing loop's exit, not the if's merge
--ARGS--
--ir -o -
--FILE--
fn f(): i32 {
  let i: i32 = 0;
  while i < 10 {
    if i == 3 {
      break;
    }
    i = i + 1;
  }
  return i;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @f() {
entry:
  %i = alloca i32
  store i32 0, ptr %i
  br label %cond.1
cond.1:
  %1 = load i32, ptr %i
  %2 = icmp slt i32 %1, 10
  br i1 %2, label %body.1, label %endwhile.1
body.1:
  %3 = load i32, ptr %i
  %4 = icmp eq i32 %3, 3
  br i1 %4, label %then.2, label %endif.2
then.2:
  br label %endwhile.1
endif.2:
  %5 = load i32, ptr %i
  %6 = add i32 %5, 1
  store i32 %6, ptr %i
  br label %cond.1
endwhile.1:
  %7 = load i32, ptr %i
  ret i32 %7
}

define i32 @main() {
entry:
  ret i32 0
}
