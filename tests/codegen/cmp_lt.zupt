--TEST--
less-than lowers to the signed predicate icmp slt
--ARGS--
--ir -o -
--FILE--
fn lt(a: i32, b: i32): bool {
  return a < b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i1 @lt(i32 %a, i32 %b) {
entry:
  %1 = icmp slt i32 %a, %b
  ret i1 %1
}

define i32 @main() {
entry:
  ret i32 0
}
