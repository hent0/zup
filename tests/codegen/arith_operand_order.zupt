--TEST--
the left operand is lowered before the right (register numbering)
--ARGS--
--ir -o -
--FILE--
fn f(a: i32, b: i32, c: i32, d: i32): i32 {
  return a * b - c * d;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i32 @f(i32 %a, i32 %b, i32 %c, i32 %d) {
entry:
  %1 = mul i32 %a, %b
  %2 = mul i32 %c, %d
  %3 = sub i32 %1, %2
  ret i32 %3
}

define i32 @main() {
entry:
  ret i32 0
}
