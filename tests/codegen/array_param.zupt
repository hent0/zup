--TEST--
an array parameter passes by pointer with byval; elements are read through it
--ARGS--
--ir -o -
--FILE--
fn sum(a: [3]i32): i32 {
  return a[0] + a[1] + a[2];
}

pub fn main(): i32 {
  let a: [3]i32 = [1, 2, 3];
  return sum(a);
}
--EXPECT--
define internal i32 @sum(ptr byval([3 x i32]) %a) {
entry:
  %1 = getelementptr [3 x i32], ptr %a, i32 0, i32 0
  %2 = load i32, ptr %1
  %3 = getelementptr [3 x i32], ptr %a, i32 0, i32 1
  %4 = load i32, ptr %3
  %5 = add i32 %2, %4
  %6 = getelementptr [3 x i32], ptr %a, i32 0, i32 2
  %7 = load i32, ptr %6
  %8 = add i32 %5, %7
  ret i32 %8
}

define i32 @main() {
entry:
  %a = alloca [3 x i32]
  %1 = getelementptr [3 x i32], ptr %a, i32 0, i32 0
  store i32 1, ptr %1
  %2 = getelementptr [3 x i32], ptr %a, i32 0, i32 1
  store i32 2, ptr %2
  %3 = getelementptr [3 x i32], ptr %a, i32 0, i32 2
  store i32 3, ptr %3
  %4 = call i32 @sum(ptr byval([3 x i32]) %a)
  ret i32 %4
}
