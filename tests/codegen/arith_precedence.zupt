--TEST--
the multiply is evaluated before the subtract
--ARGS--
--ir -o -
--FILE--
fn f(a: i32, b: i32, c: i32): i32 {
  return a - b * c;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @f(i32 %a, i32 %b, i32 %c) {
entry:
  %1 = mul i32 %b, %c
  %2 = sub i32 %a, %1
  ret i32 %2
}

define i32 @main() {
entry:
  ret i32 0
}
