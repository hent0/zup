--TEST--
equality lowers to icmp eq with an i1 result
--ARGS--
--ir -o -
--FILE--
fn eq(a: i32, b: i32): bool {
  return a == b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i1 @eq(i32 %a, i32 %b) {
entry:
  %1 = icmp eq i32 %a, %b
  ret i1 %1
}

define i32 @main() {
entry:
  ret i32 0
}
