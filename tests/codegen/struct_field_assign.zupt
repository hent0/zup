--TEST--
a field assignment lowers to getelementptr + store into the struct slot
--ARGS--
--ir -o -
--FILE--
struct Pair {
  a: i32,
  b: i32,
}

pub fn main(): i32 {
  let p: Pair = Pair { a: 3, b: 4 };
  p.a = 7;
  return p.a;
}
--EXPECT--
%Pair = type { i32, i32 }
define i32 @main() {
entry:
  %p = alloca %Pair
  %1 = getelementptr %Pair, ptr %p, i32 0, i32 0
  store i32 3, ptr %1
  %2 = getelementptr %Pair, ptr %p, i32 0, i32 1
  store i32 4, ptr %2
  %3 = getelementptr %Pair, ptr %p, i32 0, i32 0
  store i32 7, ptr %3
  %4 = getelementptr %Pair, ptr %p, i32 0, i32 0
  %5 = load i32, ptr %4
  ret i32 %5
}
