--TEST--
bool literals lower to i1 true / i1 false
--ARGS--
--ir -o -
--FILE--
fn t(): bool {
  return true;
}

fn f(): bool {
  return false;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i1 @t() {
entry:
  ret i1 true
}

define internal i1 @f() {
entry:
  ret i1 false
}

define i32 @main() {
entry:
  ret i32 0
}
