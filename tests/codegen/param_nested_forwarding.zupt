--TEST--
nested call arguments are evaluated depth-first into temporaries before each call
--ARGS--
--ir -o -
--FILE--
fn pick(x: i32, y: i32): i32 {
  return x;
}

fn forward(y: i32): i32 {
  return pick(y, 2);
}

pub fn main(): i32 {
  return forward(pick(5, pick(4, 2)));
}
--EXPECT--
define internal i32 @pick(i32 %x, i32 %y) {
entry:
  ret i32 %x
}

define internal i32 @forward(i32 %y) {
entry:
  %1 = call i32 @pick(i32 %y, i32 2)
  ret i32 %1
}

define i32 @main() {
entry:
  %1 = call i32 @pick(i32 4, i32 2)
  %2 = call i32 @pick(i32 5, i32 %1)
  %3 = call i32 @forward(i32 %2)
  ret i32 %3
}
