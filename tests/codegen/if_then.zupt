--TEST--
a plain if lowers to a conditional branch with a fallthrough block
--ARGS--
--ir -o -
--FILE--
fn pick(c: bool): i32 {
  if c {
    return 1;
  }
  return 2;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @pick(i1 %c) {
entry:
  br i1 %c, label %then.1, label %endif.1
then.1:
  ret i32 1
endif.1:
  ret i32 2
}

define i32 @main() {
entry:
  ret i32 0
}
