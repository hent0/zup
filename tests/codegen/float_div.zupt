--TEST--
f64 division lowers to fdiv (not sdiv/udiv)
--ARGS--
--ir -o -
--FILE--
fn d(a: f64, b: f64): f64 {
  return a / b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal double @d(double %a, double %b) {
entry:
  %1 = fdiv double %a, %b
  ret double %1
}

define i32 @main() {
entry:
  ret i32 0
}
