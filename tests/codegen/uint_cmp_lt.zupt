--TEST--
less-than on unsigned operands lowers to the unsigned predicate icmp ult
--ARGS--
--ir -o -
--FILE--
fn lt(a: u32, b: u32): bool {
  return a < b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i1 @lt(i32 %a, i32 %b) {
entry:
  %1 = icmp ult i32 %a, %b
  ret i1 %1
}

define i32 @main() {
entry:
  ret i32 0
}
