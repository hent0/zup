--TEST--
each parameter is emitted with its own integer type, not a hardcoded i32
--ARGS--
--ir -o -
--FILE--
fn widen(a: i8, b: i64): i64 {
  return b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i64 @widen(i8 %a, i64 %b) {
entry:
  ret i64 %b
}

define i32 @main() {
entry:
  ret i32 0
}
