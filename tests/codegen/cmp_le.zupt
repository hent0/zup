--TEST--
less-than-or-equal lowers to the signed predicate icmp sle
--ARGS--
--ir -o -
--FILE--
fn le(a: i32, b: i32): bool {
  return a <= b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i1 @le(i32 %a, i32 %b) {
entry:
  %1 = icmp sle i32 %a, %b
  ret i1 %1
}

define i32 @main() {
entry:
  ret i32 0
}
