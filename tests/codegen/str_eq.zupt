--TEST--
str equality lowers to a length check short-circuiting a memcmp; equal length then memcmp == 0
--ARGS--
--ir -o -
--FILE--
fn eq(a: str, b: str): bool {
  return a == b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @memcmp(ptr, ptr, i64)
define internal i1 @eq(ptr byval({ ptr, i64 }) %a, ptr byval({ ptr, i64 }) %b) {
entry:
  %1 = getelementptr { ptr, i64 }, ptr %a, i32 0, i32 1
  %2 = load i64, ptr %1
  %3 = getelementptr { ptr, i64 }, ptr %b, i32 0, i32 1
  %4 = load i64, ptr %3
  %5 = icmp eq i64 %2, %4
  %6 = alloca i1
  store i1 %5, ptr %6
  br i1 %5, label %streq.cmp.1, label %streq.end.1
streq.cmp.1:
  %7 = getelementptr { ptr, i64 }, ptr %a, i32 0, i32 0
  %8 = load ptr, ptr %7
  %9 = getelementptr { ptr, i64 }, ptr %b, i32 0, i32 0
  %10 = load ptr, ptr %9
  %11 = call i32 @memcmp(ptr %8, ptr %10, i64 %2)
  %12 = icmp eq i32 %11, 0
  store i1 %12, ptr %6
  br label %streq.end.1
streq.end.1:
  %13 = load i1, ptr %6
  ret i1 %13
}

define i32 @main() {
entry:
  ret i32 0
}
