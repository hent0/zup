--TEST--
passing a str value where a cstr is expected decays to the str's data pointer (getelementptr field 0 + load), not a byval fat pointer
--ARGS--
--ir -o -
--FILE--
extern fn puts(s: cstr): i32;

pub fn main(): i32 {
  let s: str = "hi";
  puts(s);
  return 0;
}
--EXPECT--
@.str.0 = private unnamed_addr constant [3 x i8] c"hi\00"
declare i32 @puts(ptr)
define i32 @main() {
entry:
  %s = alloca { ptr, i64 }
  %1 = getelementptr { ptr, i64 }, ptr %s, i32 0, i32 0
  store ptr @.str.0, ptr %1
  %2 = getelementptr { ptr, i64 }, ptr %s, i32 0, i32 1
  store i64 2, ptr %2
  %3 = getelementptr { ptr, i64 }, ptr %s, i32 0, i32 0
  %4 = load ptr, ptr %3
  %5 = call i32 @puts(ptr %4)
  ret i32 0
}
