--TEST--
remainder lowers to signed srem
--ARGS--
--ir -o -
--FILE--
fn r(a: i32, b: i32): i32 {
  return a % b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i32 @r(i32 %a, i32 %b) {
entry:
  %1 = srem i32 %a, %b
  ret i32 %1
}

define i32 @main() {
entry:
  ret i32 0
}
