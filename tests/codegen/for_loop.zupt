--TEST--
a range for loop lowers to a loop-var slot, a condition, a body, an increment, and a back-edge
--ARGS--
--ir -o -
--FILE--
fn count(n: i32): i32 {
  let total: i32 = 0;
  for i in 0..n {
    total = total + i;
  }
  return total;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i32 @count(i32 %n) {
entry:
  %total = alloca i32
  store i32 0, ptr %total
  %i = alloca i32
  store i32 0, ptr %i
  br label %cond.1
cond.1:
  %1 = load i32, ptr %i
  %2 = icmp slt i32 %1, %n
  br i1 %2, label %body.1, label %endwhile.1
body.1:
  %3 = load i32, ptr %total
  %4 = load i32, ptr %i
  %5 = add i32 %3, %4
  store i32 %5, ptr %total
  %6 = load i32, ptr %i
  %7 = add i32 %6, 1
  store i32 %7, ptr %i
  br label %cond.1
endwhile.1:
  %8 = load i32, ptr %total
  ret i32 %8
}

define i32 @main() {
entry:
  ret i32 0
}
