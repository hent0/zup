--TEST--
a float to unsigned int cast lowers to fptoui
--ARGS--
--ir -o -
--FILE--
fn to_uint(x: f64): u32 {
  return x as u32;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @to_uint(double %x) {
entry:
  %1 = fptoui double %x to i32
  ret i32 %1
}

define i32 @main() {
entry:
  ret i32 0
}
