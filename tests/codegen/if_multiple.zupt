--TEST--
two ifs in one function get distinct, counter-suffixed labels
--ARGS--
--ir -o -
--FILE--
fn f(a: bool, b: bool): i32 {
  if a {
    return 1;
  }
  if b {
    return 2;
  }
  return 3;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @f(i1 %a, i1 %b) {
entry:
  br i1 %a, label %then.1, label %endif.1
then.1:
  ret i32 1
endif.1:
  br i1 %b, label %then.2, label %endif.2
then.2:
  ret i32 2
endif.2:
  ret i32 3
}

define i32 @main() {
entry:
  ret i32 0
}
