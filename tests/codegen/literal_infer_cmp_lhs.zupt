--TEST--
a literal on the left of a comparison infers the other operand's type (i64 width)
--ARGS--
--ir -o -
--FILE--
fn f(n: i64): bool {
  return 100 < n;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i1 @f(i64 %n) {
entry:
  %1 = icmp slt i64 100, %n
  ret i1 %1
}

define i32 @main() {
entry:
  ret i32 0
}
