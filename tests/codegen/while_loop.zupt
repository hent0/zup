--TEST--
a while loop lowers to a condition block, a body, and a back-edge
--ARGS--
--ir -o -
--FILE--
fn count(n: i32): i32 {
  let i: i32 = 0;
  while i < n {
    i = i + 1;
  }
  return i;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @count(i32 %n) {
entry:
  %i = alloca i32
  store i32 0, ptr %i
  br label %cond.1
cond.1:
  %1 = load i32, ptr %i
  %2 = icmp slt i32 %1, %n
  br i1 %2, label %body.1, label %endwhile.1
body.1:
  %3 = load i32, ptr %i
  %4 = add i32 %3, 1
  store i32 %4, ptr %i
  br label %step.1
step.1:
  br label %cond.1
endwhile.1:
  %5 = load i32, ptr %i
  ret i32 %5
}

define i32 @main() {
entry:
  ret i32 0
}
