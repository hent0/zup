--TEST--
a narrowing integer cast lowers to trunc
--ARGS--
--ir -o -
--FILE--
fn narrow(x: i64): i8 {
  return x as i8;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i8 @narrow(i64 %x) {
entry:
  %1 = trunc i64 %x to i8
  ret i8 %1
}

define i32 @main() {
entry:
  ret i32 0
}
