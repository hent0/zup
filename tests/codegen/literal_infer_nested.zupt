--TEST--
inference threads through nested operators: 'x + 1 > 100' infers u8 for both literals
--ARGS--
--ir -o -
--FILE--
fn f(x: u8): bool {
  return x + 1 > 100;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i1 @f(i8 %x) {
entry:
  %1 = add i8 %x, 1
  %2 = icmp ugt i8 %1, 100
  ret i1 %2
}

define i32 @main() {
entry:
  ret i32 0
}
