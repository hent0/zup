--TEST--
unsigned division lowers to udiv (and u32 lowers to the i32 IR type)
--ARGS--
--ir -o -
--FILE--
fn d(a: u32, b: u32): u32 {
  return a / b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @d(i32 %a, i32 %b) {
entry:
  %1 = udiv i32 %a, %b
  ret i32 %1
}

define i32 @main() {
entry:
  ret i32 0
}
