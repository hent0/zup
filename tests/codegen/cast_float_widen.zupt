--TEST--
an f32 to f64 cast lowers to fpext
--ARGS--
--ir -o -
--FILE--
fn widen(x: f32): f64 {
  return x as f64;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal double @widen(float %x) {
entry:
  %1 = fpext float %x to double
  ret double %1
}

define i32 @main() {
entry:
  ret i32 0
}
