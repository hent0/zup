--TEST--
break inside a for loop branches to the loop exit and skips the increment / back-edge
--ARGS--
--ir -o -
--FILE--
fn f(): i32 {
  for i in 0..3 {
    break;
  }
  return 0;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @f() {
entry:
  %i = alloca i32
  store i32 0, ptr %i
  br label %cond.1
cond.1:
  %1 = load i32, ptr %i
  %2 = icmp slt i32 %1, 3
  br i1 %2, label %body.1, label %endwhile.1
body.1:
  br label %endwhile.1
endwhile.1:
  ret i32 0
}

define i32 @main() {
entry:
  ret i32 0
}
