--TEST--
unary minus lowers to sub from zero
--ARGS--
--ir -o -
--FILE--
fn neg(x: i32): i32 {
  return -x;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i32 @neg(i32 %x) {
entry:
  %1 = sub i32 0, %x
  ret i32 %1
}

define i32 @main() {
entry:
  ret i32 0
}
