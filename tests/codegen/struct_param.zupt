--TEST--
a struct type name resolves in a parameter signature and renders as the named LLVM type
--ARGS--
--ir -o -
--FILE--
struct Foo {}

fn take(x: Foo) {
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
%Foo = type {}
define internal void @take(%Foo %x) {
entry:
  ret void
}

define i32 @main() {
entry:
  ret i32 0
}
