--TEST--
an f64 to f32 cast lowers to fptrunc
--ARGS--
--ir -o -
--FILE--
fn narrow(x: f64): f32 {
  return x as f32;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal float @narrow(double %x) {
entry:
  %1 = fptrunc double %x to float
  ret float %1
}

define i32 @main() {
entry:
  ret i32 0
}
