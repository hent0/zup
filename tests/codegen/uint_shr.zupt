--TEST--
right shift on an unsigned operand lowers to a logical shift (lshr), not arithmetic
--ARGS--
--ir -o -
--FILE--
fn f(a: u32, b: u32): u32 {
  return a >> b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
define internal i32 @f(i32 %a, i32 %b) {
entry:
  %1 = lshr i32 %a, %b
  ret i32 %1
}

define i32 @main() {
entry:
  ret i32 0
}
