--TEST--
a void function still emits its parameters in the signature
--ARGS--
--ir -o -
--FILE--
fn noop(x: i32) {
  return;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal void @noop(i32 %x) {
entry:
  ret void
}

define i32 @main() {
entry:
  ret i32 0
}
