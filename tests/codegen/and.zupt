--TEST--
&& short-circuits: the rhs is only evaluated when the lhs is true
--ARGS--
--ir -o -
--FILE--
fn f(a: bool, b: bool): bool {
  return a && b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
declare i32 @printf(ptr, ...)

define internal i1 @f(i1 %a, i1 %b) {
entry:
  %1 = alloca i1
  store i1 %a, ptr %1
  br i1 %a, label %and.rhs.1, label %and.end.1
and.rhs.1:
  store i1 %b, ptr %1
  br label %and.end.1
and.end.1:
  %2 = load i1, ptr %1
  ret i1 %2
}

define i32 @main() {
entry:
  ret i32 0
}
