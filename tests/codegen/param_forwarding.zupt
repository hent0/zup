--TEST--
parameters lower to typed args; a param flows into a call and out as a return
--ARGS--
--ir -o -
--FILE--
fn pick(x: i32): i32 {
  return x;
}

fn forward(y: i32): i32 {
  return pick(y);
}

pub fn main(): i32 {
  return forward(5);
}
--EXPECT--
define internal i32 @pick(i32 %x) {
entry:
  ret i32 %x
}

define internal i32 @forward(i32 %y) {
entry:
  %1 = call i32 @pick(i32 %y)
  ret i32 %1
}

define i32 @main() {
entry:
  %1 = call i32 @forward(i32 5)
  ret i32 %1
}
