--TEST--
the && and || operators tokenize
--ARGS--
--tokenize
--FILE--
pub fn main(): i32 {
  return true && false || true;
}
--EXPECT--
TOKEN_PUB [1:1]
TOKEN_FN [1:5]
TOKEN_ID('main') [1:8]
TOKEN_LPAREN [1:12]
TOKEN_RPAREN [1:13]
TOKEN_COLON [1:14]
TOKEN_I32 [1:16]
TOKEN_LBRACE [1:20]
TOKEN_RETURN [2:3]
TOKEN_TRUE [2:10]
TOKEN_AMPERSAND_AMPERSAND [2:15]
TOKEN_FALSE [2:18]
TOKEN_PIPE_PIPE [2:24]
TOKEN_TRUE [2:27]
TOKEN_SEMICOLON [2:31]
TOKEN_RBRACE [3:1]
