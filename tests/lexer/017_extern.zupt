--TEST--
extern, cstr and the variadic ellipsis tokenize as distinct keywords/punctuation
--ARGS--
--tokenize
--FILE--
extern fn printf(fmt: cstr, ...): i32;
--EXPECT--
TOKEN_EXTERN [1:1]
TOKEN_FN [1:8]
TOKEN_ID('printf') [1:11]
TOKEN_LPAREN [1:17]
TOKEN_ID('fmt') [1:18]
TOKEN_COLON [1:21]
TOKEN_CSTR [1:23]
TOKEN_COMMA [1:27]
TOKEN_DOT_DOT_DOT [1:29]
TOKEN_RPAREN [1:32]
TOKEN_COLON [1:33]
TOKEN_I32 [1:35]
TOKEN_SEMICOLON [1:38]
