--TEST--
string literal escape sequences are decoded by the lexer
--ARGS--
--tokenize
--FILE--
pub fn main(): i32 {
  printf("Hello, world\n");
  return 0;
}
--EXPECT--
TOKEN_PUB [1:1]
TOKEN_FN [1:5]
TOKEN_ID('main') [1:8]
TOKEN_LPAREN [1:12]
TOKEN_RPAREN [1:13]
TOKEN_COLON [1:14]
TOKEN_I32 [1:16]
TOKEN_LBRACE [1:20]
TOKEN_ID('printf') [2:3]
TOKEN_LPAREN [2:9]
TOKEN_STRING('Hello, world\n') [2:10]
TOKEN_RPAREN [2:26]
TOKEN_SEMICOLON [2:27]
TOKEN_RETURN [3:3]
TOKEN_NUMBER(0) [3:10]
TOKEN_SEMICOLON [3:11]
TOKEN_RBRACE [4:1]
