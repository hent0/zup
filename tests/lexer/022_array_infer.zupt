--TEST--
the inferred-length marker [_] uses a dedicated underscore token
--ARGS--
--tokenize
--FILE--
const a: [_]i32 = [1, 2];
--EXPECT--
TOKEN_CONST [1:1]
TOKEN_ID('a') [1:7]
TOKEN_COLON [1:8]
TOKEN_LBRACKET [1:10]
TOKEN_UNDERSCORE [1:11]
TOKEN_RBRACKET [1:12]
TOKEN_I32 [1:13]
TOKEN_EQUAL [1:17]
TOKEN_LBRACKET [1:19]
TOKEN_NUMBER(1) [1:20]
TOKEN_COMMA [1:21]
TOKEN_NUMBER(2) [1:23]
TOKEN_RBRACKET [1:24]
TOKEN_SEMICOLON [1:25]
