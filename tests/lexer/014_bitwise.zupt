--TEST--
bitwise operators & | ^ << >> tokenize
--ARGS--
--tokenize
--FILE--
pub fn main(): i32 {
  return 1 & 2 | 3 ^ 4 << 5 >> 6;
}
--EXPECT--
TOKEN_PUB [1:1]
TOKEN_FN [1:5]
TOKEN_ID('main') [1:8]
TOKEN_LPAREN [1:12]
TOKEN_RPAREN [1:13]
TOKEN_COLON [1:14]
TOKEN_I32 [1:16]
TOKEN_LBRACE [1:20]
TOKEN_RETURN [2:3]
TOKEN_NUMBER(1) [2:10]
TOKEN_AMPERSAND [2:12]
TOKEN_NUMBER(2) [2:14]
TOKEN_PIPE [2:16]
TOKEN_NUMBER(3) [2:18]
TOKEN_CARET [2:20]
TOKEN_NUMBER(4) [2:22]
TOKEN_LESS_LESS [2:24]
TOKEN_NUMBER(5) [2:27]
TOKEN_GREATER_GREATER [2:29]
TOKEN_NUMBER(6) [2:32]
TOKEN_SEMICOLON [2:33]
TOKEN_RBRACE [3:1]
