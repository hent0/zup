--TEST--
the if and else keywords tokenize
--ARGS--
--tokenize
--FILE--
pub fn main(): i32 {
  if true {
    return 1;
  } else {
    return 0;
  }
}
--EXPECT--
TOKEN_PUB [1:1]
TOKEN_FN [1:5]
TOKEN_ID('main') [1:8]
TOKEN_LPAREN [1:12]
TOKEN_RPAREN [1:13]
TOKEN_COLON [1:14]
TOKEN_I32 [1:16]
TOKEN_LBRACE [1:20]
TOKEN_IF [2:3]
TOKEN_TRUE [2:6]
TOKEN_LBRACE [2:11]
TOKEN_RETURN [3:5]
TOKEN_NUMBER(1) [3:12]
TOKEN_SEMICOLON [3:13]
TOKEN_RBRACE [4:3]
TOKEN_ELSE [4:5]
TOKEN_LBRACE [4:10]
TOKEN_RETURN [5:5]
TOKEN_NUMBER(0) [5:12]
TOKEN_SEMICOLON [5:13]
TOKEN_RBRACE [6:3]
TOKEN_RBRACE [7:1]
