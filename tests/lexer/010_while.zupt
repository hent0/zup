--TEST--
the while keyword tokenizes
--ARGS--
--tokenize
--FILE--
pub fn main(): i32 {
  while true {
    return 0;
  }
  return 1;
}
--EXPECT--
TOKEN_PUB [1:1]
TOKEN_FN [1:5]
TOKEN_ID('main') [1:8]
TOKEN_LPAREN [1:12]
TOKEN_RPAREN [1:13]
TOKEN_COLON [1:14]
TOKEN_I32 [1:16]
TOKEN_LBRACE [1:20]
TOKEN_WHILE [2:3]
TOKEN_TRUE [2:9]
TOKEN_LBRACE [2:14]
TOKEN_RETURN [3:5]
TOKEN_NUMBER(0) [3:12]
TOKEN_SEMICOLON [3:13]
TOKEN_RBRACE [4:3]
TOKEN_RETURN [5:3]
TOKEN_NUMBER(1) [5:10]
TOKEN_SEMICOLON [5:11]
TOKEN_RBRACE [6:1]
