--TEST--
'!' tokenizes as its own token, distinct from '!='
--ARGS--
--tokenize
--FILE--
pub fn main(): i32 {
  return !true != false;
}
--EXPECT--
TOKEN_PUB [1:1]
TOKEN_FN [1:5]
TOKEN_ID('main') [1:8]
TOKEN_LPAREN [1:12]
TOKEN_RPAREN [1:13]
TOKEN_COLON [1:14]
TOKEN_I32 [1:16]
TOKEN_LBRACE [1:20]
TOKEN_RETURN [2:3]
TOKEN_BANG [2:10]
TOKEN_TRUE [2:11]
TOKEN_BANG_EQUAL [2:16]
TOKEN_FALSE [2:19]
TOKEN_SEMICOLON [2:24]
TOKEN_RBRACE [3:1]
