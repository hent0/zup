--TEST--
arguments to a module-qualified call are type-checked against the imported function's parameters
--FILE--
const std = import("std");

pub fn main(): i32 {
  std.io.println(5);
  return 0;
}
--EXPECTERR--
zup: error: cannot pass i32 as argument 'fmt' of 'println' (expected str) [4:10]
--EXIT--
1
