--TEST--
a variant that stores its own enum by value is infinitely sized and rejected
--FILE--
enum List {
  Nil,
  Cons: List,
}

pub fn main(): i32 {
  return 0;
}
--EXPECTERR--
zup: error: variant 'Cons' makes enum 'List' recursive by value and infinitely sized; break the cycle with a slice [3:3]
--EXIT--
1
