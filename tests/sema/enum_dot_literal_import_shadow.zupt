--TEST--
a local enum sharing its name with an imported enum does not hijack dot-literal inference at a cross-module call site
--FILE--
const std = import("std");

enum Mode {
  Compile,
  Tokenize,
}

pub fn main(): i32 {
  const local: Mode = .Tokenize;
  if local != .Tokenize {
    return 1;
  }

  match std.io.open("/nonexistent/zup_enum_shadow_test", .Read) {
    .Ok(f) => { return 2; },
    .Err(e) => {},
  };

  let m: std.io.Mode = .Read;
  match std.io.open("/nonexistent/zup_enum_shadow_test", m) {
    .Ok(g) => { return 3; },
    .Err(e) => {},
  };

  std.io.println("ok");
  return 0;
}
--EXPECT--
ok
--EXIT--
0
