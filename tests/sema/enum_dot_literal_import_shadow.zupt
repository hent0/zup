--TEST--
a local enum sharing its name with an imported enum does not hijack dot-literal inference at a cross-module call site
--FILE--
const std = import("std");

enum Mode {
  Compile,
  Tokenize,
}

pub fn main(): i32 {
  const local: Mode = .Tokenize;
  if local != .Tokenize {
    return 1;
  }

  const f = std.io.open("/nonexistent/zup_enum_shadow_test", .Read);
  if f != null {
    return 2;
  }

  let m: std.io.Mode = .Read;
  const g = std.io.open("/nonexistent/zup_enum_shadow_test", m);
  if g != null {
    return 3;
  }

  std.io.println("ok");
  return 0;
}
--EXPECT--
ok
--EXIT--
0
