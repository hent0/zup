--TEST--
a parameter without a default may not follow a defaulted one (positional calls would be ambiguous)
--FILE--
fn f(a: i32 = 1, b: i32): i32 {
  return a + b;
}

pub fn main(): i32 {
  return 0;
}
--EXPECTERR--
zup: error: parameter 'b' without a default cannot follow a defaulted parameter [1:1]
--EXIT--
1
