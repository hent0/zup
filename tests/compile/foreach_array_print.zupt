--TEST--
for-in over an array literal binds each element in order; matches the 006_sum example's main
--FILE--
extern fn printf(fmt: cstr, ...);

pub fn main(): i32 {
  let sum = 0;
  printf("Sum of:\n");
  for i in [1, 2, 3] {
    printf("%d\n", i);
    sum = sum + i;
  }

  printf("Equals: %d\n", sum);

  return 0;
}
--EXPECT--
Sum of:
1
2
3
Equals: 6
--EXIT--
0
