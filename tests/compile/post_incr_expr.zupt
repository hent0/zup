--TEST--
postfix ++ / -- work as expressions, yielding the old value then updating in place
--FILE--
const std = import("std");

struct Counter {
  n: i32,
}

fn take(a: i32, b: i32): i32 {
  return a * 100 + b;
}

pub fn main(): i32 {
  let n: i32 = 1;
  const a: i32 = n++;            // a = 1, n = 2
  const b: i32 = n++;            // b = 2, n = 3
  const c: i32 = n--;            // c = 3, n = 2
  std.io.println("a={} b={} c={} n={}", a, b, c, n);

  // as a call argument (evaluated left to right)
  let k: i32 = 5;
  const r: i32 = take(k++, k++); // take(5, 6), k = 7
  std.io.println("r={} k={}", r, k);

  // as an index target inside an expression
  let arr: [3]i32;
  let i: i32 = 0;
  arr[i++] = 10;                 // arr[0] = 10, i = 1
  arr[i++] = 20;                 // arr[1] = 20, i = 2
  std.io.println("arr0={} arr1={} i={}", arr[0], arr[1], i);

  // field target
  let ctr: Counter = Counter{n: 41};
  const old: i32 = ctr.n++;      // old = 41, ctr.n = 42
  std.io.println("old={} ctr={}", old, ctr.n);
  return 0;
}
--EXPECT--
a=1 b=2 c=3 n=2
r=506 k=7
arr0=10 arr1=20 i=2
old=41 ctr=42
--EXIT--
0
