--TEST--
match selects the arm whose enum member equals the scrutinee, with '_' as the default
--FILE--
const std = import("std");

enum Color {
  Red,
  Green,
  Blue,
}

fn name(c: Color): str {
  return match c {
    .Red => "red",
    .Green => "green",
    _ => "other",
  };
}

pub fn main(): i32 {
  std.io.println("{}", name(Color.Green));
  std.io.println("{}", name(Color.Blue));
  return 0;
}
--EXPECT--
green
other
--EXIT--
0
