--TEST--
public fields and methods of an imported struct are accessible across the module boundary; a private defaulted field is simply omitted at construction
--PREPARE--
printf 'pub struct Point {\n  pub x: i32,\n  pub y: i32,\n  secret: i32 = 0,\n\n  pub fn sum(self): i32 {\n    return self.x + self.y;\n  }\n\n  fn hidden(self): i32 {\n    return self.secret;\n  }\n}\n' > "${TMPDIR:-/tmp}/zup_point.zup"
--FILE--
const m = import("zup_point.zup");

pub fn main(): i32 {
  let p: m.Point = m.Point { x: 3, y: 4 };
  return p.sum() + p.x;
}
--CLEANUP--
rm -f "${TMPDIR:-/tmp}/zup_point.zup"
--EXIT--
10
