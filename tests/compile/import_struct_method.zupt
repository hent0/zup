--TEST--
a method on an imported struct is callable across the module boundary, mangled to the struct's owning module
--PREPARE--
printf 'pub struct Rect {\n  w: i32,\n  h: i32,\n\n  fn area(self): i32 {\n    return self.w * self.h;\n  }\n}\n' > "${TMPDIR:-/tmp}/zup_shapes.zup"
--FILE--
const m = import("zup_shapes.zup");

pub fn main(): i32 {
  let r: m.Rect = m.Rect { w: 4, h: 5 };
  return r.area();
}
--CLEANUP--
rm -f "${TMPDIR:-/tmp}/zup_shapes.zup"
--EXIT--
20
