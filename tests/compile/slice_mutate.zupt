--TEST--
a slice is a view: writing through a slice parameter mutates the caller's array
--FILE--
extern fn printf(fmt: cstr, ...): i32;

fn set(a: []i32) {
  a[0] = 99;
}

pub fn main(): i32 {
  let xs: [2]i32 = [1, 2];
  set(xs);
  printf("%d %d\n", xs[0], xs[1]);
  return 0;
}
--EXPECT--
99 2
--EXIT--
0
