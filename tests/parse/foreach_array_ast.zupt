--TEST--
for-in over an array literal parses with the literal as the iterable
--ARGS--
--ast
--FILE--
pub fn main(): i32 {
  let total = 0;
  for i in [1, 2, 3] {
    total = total + i;
  }
  return total;
}
--EXPECT--
