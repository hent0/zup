  FnDecl pub 'main' -> i32
    Let total: i32
      Number literal 0
    For i
      Iter
        Array (3 elements)
          Number literal 1
          Number literal 2
          Number literal 3
      Do
        Assign total
          Binary +
            Id total
            Id i
    Return
      Id total
--EXIT--
0
