--TEST--
break and continue parse when guarded by an if/else inside a loop
--ARGS--
--ast
--FILE--
pub fn main(): i32 {
  let i: i32 = 0;
  while i < 10 {
    if i == 3 {
      break;
    } else {
      continue;
    }
  }
  return i;
}
--EXPECT--
Container (file) (1 members)
  FnDecl pub 'main' -> i32
    Let i: i32
      Number literal 0
    While
      Binary <
        Id i
        Number literal 10
      Do
        If
          Binary =
            Id i
            Number literal 3
          Then
            Break
          Else
            Continue
    Return
      Id i
