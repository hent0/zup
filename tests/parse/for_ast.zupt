--TEST--
a range for loop parses into a loop variable, a range, and a body
--ARGS--
--ast
--FILE--
pub fn main(): i32 {
  let sum: i32 = 0;
  for i in 0..5 {
    sum = sum + i;
  }
  return sum;
}
