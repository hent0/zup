--TEST--
an inferred-length array type T[_] has its length filled in from the initializer
--ARGS--
--ast
--FILE--
pub fn main(): i32 {
  const a: [_]i32 = [1, 2, 3];
  return a[0];
}
--EXPECT--
Container (file) (1 members)
  FnDecl pub 'main' -> i32
    Const a: [3]i32
      Array (3 elements)
        Number literal 1
        Number literal 2
        Number literal 3
    Return
      Index
        Id a
        Number literal 0
--EXIT--
0
