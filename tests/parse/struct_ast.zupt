--TEST--
a struct declares fields; a struct literal constructs one and '.' reads a field
--ARGS--
--ast
--FILE--
struct Point {
  x: i32,
  y: i32,
}

fn dist(): i32 {
  let p: Point = Point { x: 1, y: 2 };
  return p.x;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
Container (file) (3 members)
  Struct priv 'Point'
    field x: i32
    field y: i32
  FnDecl priv 'dist' -> i32
    Let p: Point
      StructLit 'Point'
        field x
          Number literal 1
        field y
          Number literal 2
    Return
      Field x
        Id p
  FnDecl pub 'main' -> i32
    Return
      Number literal 0
--EXIT--
0
