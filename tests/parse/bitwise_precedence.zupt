--TEST--
bitwise & binds tighter than bitwise |
--ARGS--
--ast
--FILE--
fn f(a: i32, b: i32, c: i32): i32 {
  return a | b & c;
}

pub fn main(): i32 {
  return 0;
}
--EXPECT--
Container (file) (2 members)
  FnDecl priv 'f' -> i32
    param a: i32
    param b: i32
    param c: i32
    Return
      Binary |
        Id a
        Binary &
          Id b
          Id c
  FnDecl pub 'main' -> i32
    Return
      Number literal 0
--EXIT--
0
