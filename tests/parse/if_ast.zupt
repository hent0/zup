--TEST--
an if/else statement parses with condition, then-body and else-body
--ARGS--
--ast
--FILE--
pub fn main(): i32 {
  if true {
    return 1;
  } else {
    return 0;
  }
}
--EXPECT--
Container (file) (1 members)
  FnDecl pub 'main' -> i32
    If
      Boolean literal true
      Then
        Return
          Number literal 1
      Else
        Return
          Number literal 0
--EXIT--
0
