const std = import("std");
const flag = import("flag");
const compiler = import("compiler.zup");
const diag = import("diag.zup");

const version = "0.0.1";

extern fn isatty(fd: i32): i32;

fn parseArgs(args: []str): compiler.CompilerOpts {
  let fs = flag.FlagSet.init()
    .addStr("o", "", "output path")
    .addBool("tokenize", false, "output only tokens")
    .addBool("ir", false, "output only LLVM IR")
    .addBool("ast", false, "dump ast")
    .addBool("keep-ir", false, "keep generated LLVM IR after compile")
    .addBool("static", false, "compile static")
    .addStrList("l", "link against library (passed to clang as -l<lib>)")
    .addStrList("L", "add library search path")
    .addStr("error-format", "", "error output format: short|pretty (default: pretty on a terminal)")
    .addBool("version", false, "print version")
    .parse(args);

  if fs.getBool("version") {
    std.io.println("zup {}", version);
    std.exit(0);
  }

  const rest = fs.args();
  if rest.len < 1 {
    std.io.printerrln("error: no input provided");
    fs.usage();
    std.exit(1);
  }

  const mode: compiler.Mode = match true {
    fs.getBool("ir") => .Ir,
    fs.getBool("ast") => .Ast,
    fs.getBool("tokenize") => .Tokenize,
    _ => .Compile,
  };

  let output: ?str = null;
  if fs.getStr("o").len > 0 {
    output = fs.getStr("o");
  }

  const efmt = fs.getStr("error-format");
  if efmt != "" && efmt != "short" && efmt != "pretty" {
    std.io.printerrln("error: invalid value \"{}\" for -error-format (expected short|pretty)", efmt);
    std.exit(2);
  }

  let error_format: diag.ErrorFormat = .Short;
  if efmt == "pretty" || (efmt == "" && isatty(2) != 0) {
    error_format = .Pretty;
  }

  return compiler.CompilerOpts.init(
    rest[0],
    output,
    mode,
    fs.getBool("keep-ir"),
    fs.getBool("static"),
    fs.getStrList("l"),
    fs.getStrList("L"),
    error_format
  );
}

pub fn main(args: []str): i32 {
  const opts = parseArgs(args);

  const arena = std.mem.Arena.init();
  defer arena.destroy();

  const c = compiler.Compiler.init(&arena);
  c.compile(opts);

  return 0;
}
