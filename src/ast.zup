      let i: i64 = 0;
      while i < self.len {
        bigger[i] = self.items[i];
        i += 1;
      }
      self.items = bigger;
    }

    self.items[self.len] = stmt;
    self.len += 1;
    return (self.len - 1) as u32;
  }

  pub fn at(self, idx: u32): *Stmt {
    return &self.items[idx as i64];
  }
}

