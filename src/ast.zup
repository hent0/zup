pub struct U32List {
  arena: *std.mem.Arena,
  items: []u32,
  pub len: i64,

  pub fn init(arena: *std.mem.Arena): U32List {
    let l: U32List;
    l.arena = arena;
    return l;
  }

  pub fn push(self, idx: u32) {
    if self.len == self.items.len {
      const cap: i64 = self.items.len == 0 ? 8 : self.items.len * 2;
      let bigger = self.arena.alloc(cap * sizeof(u32)) as []u32;
      let i: i64 = 0;
      while i < self.len {
        bigger[i] = self.items[i];
        i += 1;
      }
      self.items = bigger;
    }
    self.items[self.len] = idx;
    self.len += 1;
  }

  pub fn get(self, i: i64): u32 {
    return self.items[i];
  }
}

pub struct U32Pool {
  arena: *std.mem.Arena,
  items: []u32,
  pub len: i64,

  pub fn init(arena: *std.mem.Arena): U32Pool {
    let p: U32Pool;
    p.arena = arena;
    p.push(0);
    return p;
  }

  pub fn push(self, extra: u32): u32 {
    if self.len == self.items.len {
      const cap: i64 = self.items.len == 0 ? 8 : self.items.len * 2;
      let bigger = self.arena.alloc(cap * sizeof(u32)) as []u32;
      let i: i64 = 0;
      while i < self.len {
        bigger[i] = self.items[i];
        i += 1;
      }
      self.items = bigger;
    }

    self.items[self.len] = extra;
    self.len += 1;
    return (self.len - 1) as u32;
  }

  pub fn get(self, idx: u32): u32 {
    return self.items[idx as i64];
  }

  pub fn append(self, list: U32List): Range {
    const start = self.len as u32;
    let i: i64 = 0;
    while i < list.len {
      self.push(list.items[i]);
      i += 1;
    }
    return Range{start: start, len: list.len as u32};
  }
}

// =============== Module ===============

pub struct Module {
  pub path: str,
  pub root: u32,
  pub loading: bool,
}

pub struct ModuleList {
  arena: *std.mem.Arena,
  items: []Module,
  pub len: i64,

  pub fn init(arena: *std.mem.Arena): ModuleList {
    let l: ModuleList;
    l.arena = arena;
    let nil: Module;
    l.push(nil);
    return l;
  }

  pub fn push(self, m: Module): u32 {
    if self.len == self.items.len {
      const cap: i64 = self.items.len == 0 ? 8 : self.items.len * 2;
      let bigger = self.arena.alloc(cap * sizeof(Module)) as []Module;
      let i: i64 = 0;
      while i < self.len {
        bigger[i] = self.items[i];
        i += 1;
      }
      self.items = bigger;
    }

    self.items[self.len] = m;
    self.len += 1;
    return (self.len - 1) as u32;
  }

  pub fn at(self, idx: u32): *Module {
    return &self.items[idx as i64];
  }
}

// =============== Ast ===============

pub struct Ast {
  pub arena: *std.mem.Arena,
  pub exprs: ExprPool,
  pub stmts: StmtPool,
  pub decls: DeclPool,
  pub types: TypePool,
  pub params: ParamPool,
  pub fields: FieldPool,
  pub enum_members: EnumMemberPool,
  pub match_arms: MatchArmPool,
  pub field_inits: FieldInitPool,
  pub extra: U32Pool,
  pub modules: ModuleList,

  pub fn init(arena: *std.mem.Arena): Ast {
    return {
      arena: arena,
      exprs: ExprPool.init(arena),
      stmts: StmtPool.init(arena),
      decls: DeclPool.init(arena),
      types: TypePool.init(arena),
      params: ParamPool.init(arena),
      fields: FieldPool.init(arena),
      enum_members: EnumMemberPool.init(arena),
      match_arms: MatchArmPool.init(arena),
      field_inits: FieldInitPool.init(arena),
      extra: U32Pool.init(arena),
      modules: ModuleList.init(arena),
    };
  }

  // =============== Expressions ===============

  fn pushExpr(self, span: diag.Span, kind: ExprKind): u32 {
    return self.exprs.push(Expr.init(span, kind));
  }

  pub fn binary(self, op: BinaryOp, lhs: u32, rhs: u32): u32 {
    return self.pushExpr(self.exprs.at(lhs).span, .Binary(BinaryExpr{op: op, lhs: lhs, rhs: rhs}));
  }

  pub fn unary(self, op: UnaryOp, operand: u32): u32 {
    return self.pushExpr(self.exprs.at(operand).span, .Unary(UnaryExpr{op: op, operand: operand}));
  }

  pub fn boolean(self, value: bool, span: diag.Span): u32 {
    let e = Expr.init(span, .Boolean(value));
    e.ty.kind = .Bool;
    return self.exprs.push(e);
  }

  pub fn number(self, span: diag.Span, value: str): u32 {
    return self.pushExpr(span, .Number(value));
  }

  pub fn string(self, span: diag.Span, value: str): u32 {
    return self.pushExpr(span, .String(value));
  }

  pub fn id(self, span: diag.Span, name: str): u32 {
    return self.pushExpr(span, .Id(name));
  }

  pub fn call(self, callee: u32, args: Range, type_scoped: bool): u32 {
    return self.pushExpr(self.exprs.at(callee).span, .Call(CallExpr{callee: callee, args: args, type_scoped: type_scoped}));
  }

  pub fn cast(self, operand: u32, target: Type): u32 {
    return self.pushExpr(self.exprs.at(operand).span, .Cast(CastExpr{operand: operand, target: target}));
  }

  pub fn sizeofExpr(self, span: diag.Span, target: Type): u32 {
    return self.pushExpr(span, .Sizeof(target));
  }

  pub fn structLiteral(self, span: diag.Span, type_name: str, module: str, inits: Range): u32 {
    return self.pushExpr(span, .StructLiteral(StructLiteralExpr{type_name: type_name, module: module, inits: inits}));
  }

  pub fn fieldAccess(self, base: u32, span: diag.Span, name: str): u32 {
    return self.pushExpr(span, .Field(FieldExpr{base: base, name: name}));
  }

  pub fn enumLiteral(self, span: diag.Span, name: str, payload: u32): u32 {
    return self.pushExpr(span, .EnumLiteral(EnumLiteralExpr{name: name, payload: payload}));
  }

  pub fn array(self, span: diag.Span, elements: Range): u32 {
    return self.pushExpr(span, .Array(elements));
  }

  pub fn index(self, base: u32, idx: u32): u32 {
    return self.pushExpr(self.exprs.at(base).span, .Index(IndexExpr{base: base, index: idx}));
  }

  pub fn sliceRange(self, base: u32, start: u32, end: u32): u32 {
    return self.pushExpr(self.exprs.at(base).span, .SliceRange(SliceRangeExpr{base: base, start: start, end: end}));
  }

  pub fn matchExpr(self, span: diag.Span, scrutinee: u32, arms: Range): u32 {
    return self.pushExpr(span, .Match(MatchExpr{scrutinee: scrutinee, arms: arms}));
  }

  pub fn nullExpr(self, span: diag.Span): u32 {
    return self.pushExpr(span, .Null);
  }

  pub fn coalesce(self, lhs: u32, rhs: u32): u32 {
    return self.pushExpr(self.exprs.at(lhs).span, .Coalesce(PairExpr{lhs: lhs, rhs: rhs}));
  }

  pub fn unwrap(self, operand: u32): u32 {
    return self.pushExpr(self.exprs.at(operand).span, .Unwrap(operand));
  }

  pub fn propagate(self, operand: u32): u32 {
    return self.pushExpr(self.exprs.at(operand).span, .Propagate(operand));
  }

  pub fn postIncr(self, operand: u32, increment: bool): u32 {
    return self.pushExpr(self.exprs.at(operand).span, .PostIncr(PostIncrExpr{operand: operand, increment: increment}));
  }

  pub fn ternary(self, cond: u32, then: u32, els: u32): u32 {
    return self.pushExpr(self.exprs.at(cond).span, .Ternary(TernaryExpr{cond: cond, then: then, els: els}));
  }

  pub fn importExpr(self, span: diag.Span, path: str): u32 {
    return self.pushExpr(span, .Import(path));
  }

  // =============== Statements ===============

  fn pushStmt(self, span: diag.Span, kind: StmtKind): u32 {
    return self.stmts.push(Stmt.init(span, kind));
  }

  pub fn returnStmt(self, span: diag.Span, value: u32): u32 {
    return self.pushStmt(span, .Return(value));
  }

  pub fn exprStmt(self, span: diag.Span, value: u32): u32 {
    return self.pushStmt(span, .ExprStmt(value));
  }

  pub fn ifStmt(self, span: diag.Span, cond: u32, then_body: Range, else_body: Range): u32 {
    return self.pushStmt(span, .If(IfStmt{cond: cond, then_body: then_body, else_body: else_body}));
  }

  pub fn bindingStmt(self, span: diag.Span, name: str, ty: Type, mutable: bool, init: u32): u32 {
    return self.pushStmt(span, .Binding(BindingStmt{name: name, ty: ty, mutable: mutable, init: init}));
  }

  pub fn assignStmt(self, span: diag.Span, target: u32, value: u32, compound: bool, is_coalesce: bool, op: BinaryOp): u32 {
    return self.pushStmt(span, .Assign(AssignStmt{target: target, value: value, compound: compound, coalesce: is_coalesce, op: op}));
  }

  pub fn whileStmt(self, span: diag.Span, cond: u32, body: Range): u32 {
    return self.pushStmt(span, .While(WhileStmt{cond: cond, body: body}));
  }

  pub fn forStmt(self, span: diag.Span, variable: str, start: u32, end: u32, body: Range): u32 {
    return self.pushStmt(span, .For(ForStmt{variable: variable, start: start, end: end, iterable: 0, body: body}));
  }

  pub fn foreachStmt(self, span: diag.Span, variable: str, iterable: u32, body: Range): u32 {
    return self.pushStmt(span, .For(ForStmt{variable: variable, start: 0, end: 0, iterable: iterable, body: body}));
  }

  pub fn breakStmt(self, span: diag.Span): u32 {
    return self.pushStmt(span, .Break);
  }

  pub fn continueStmt(self, span: diag.Span): u32 {
    return self.pushStmt(span, .Continue);
  }

  pub fn deferStmt(self, span: diag.Span, value: u32): u32 {
    return self.pushStmt(span, .Defer(value));
  }

  // =============== Declarations ===============

  fn pushDecl(self, span: diag.Span, visibility: Visibility, name: str, kind: DeclKind): u32 {
    return self.decls.push(Decl.init(span, visibility, name, kind));
  }

  pub fn fnDecl(self, span: diag.Span, visibility: Visibility, name: str, params: Range, return_type: Type, body: Range, is_extern: bool, variadic: bool): u32 {
    return self.pushDecl(span, visibility, name, .Fn(FnDecl{params: params, return_type: return_type, body: body, is_extern: is_extern, variadic: variadic}));
  }

  pub fn containerDecl(self, name: str, members: Range): u32 {
    let span: diag.Span;
    return self.pushDecl(span, .Private, name, .Container(members));
  }

  pub fn structDecl(self, span: diag.Span, visibility: Visibility, name: str, field_range: Range, members: Range): u32 {
    return self.pushDecl(span, visibility, name, .Struct(StructDecl{fields: field_range, members: members}));
  }

  pub fn enumDecl(self, span: diag.Span, visibility: Visibility, name: str, members: Range, methods: Range): u32 {
    return self.pushDecl(span, visibility, name, .Enum(EnumDecl{members: members, methods: methods}));
  }

  pub fn globalDecl(self, span: diag.Span, visibility: Visibility, name: str, ty: Type, mutable: bool, init: u32): u32 {
    return self.pushDecl(span, visibility, name, .Global(GlobalDecl{ty: ty, mutable: mutable, init: init}));
  }

  pub fn importDecl(self, span: diag.Span, vis: Visibility, alias: str, path: str): u32 {
    return self.pushDecl(span, vis, alias, .Import(ImportDecl{alias: alias, path: path}));
  }
}

