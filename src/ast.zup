const std = import("std");
const diag = import("diag.zup");
const token = import("token.zup");

pub enum TypeKind {
  Unknown,
  Void,
  Bool,
  I8,
  U8,
  I16,
  U16,
  I32,
  U32,
  I64,
  U64,
  F32,
  F64,
  Cstr,
  Str,
  Struct,
  Array,
  Slice,
  Enum,
  Optional,
  Pointer,

  pub fn toString(self): str {
    return match self {
      .Void => "void",
      .Bool => "bool",
      .I8 => "i8",
      .U8 => "u8",
      .I16 => "i16",
      .U16 => "u16",
      .I32 => "i32",
      .U32 => "u32",
      .I64 => "i64",
      .U64 => "u64",
      .F32 => "f32",
      .F64 => "f64",
      .Cstr => "cstr",
      .Str => "str",
      .Slice => "[]str",
      .Enum => "enum",
      .Optional => "optional",
      .Pointer => "pointer",
      _ => "?",
    };
  }

  pub fn toIr(self): str {
    return match self {
      .Void => "void",
      .Bool => "i1",
      .I8, .U8 => "i8",
      .I16, .U16 => "i16",
      .I32, .U32 => "i32",
      .I64, .U64 => "i64",
      .F32 => "float",
      .F64 => "double",
      .Cstr, .Pointer => "ptr",
      .Str, .Slice => "{ ptr, i64 }",
      .Enum => "i32",
      _ => "?",
    };
  }

  pub fn isInteger(self): bool {
    return self.isSignedInteger() || self.isUnsignedInteger();
  }

  pub fn isSignedInteger(self): bool {
    return match self {
      .I8, .I16, .I32, .I64 => true,
      _ => false,
    };
  }

  pub fn isUnsignedInteger(self): bool {
    return match self {
      .U8, .U16, .U32, .U64 => true,
      _ => false,
    };
  }

  pub fn isFloat(self): bool {
    return match self {
      .F32, .F64 => true,
      _ => false,
    };
  }

  pub fn isNumeric(self): bool {
    return self.isInteger() || self.isFloat();
  }
}

pub struct Type {
  pub kind: TypeKind,
  pub name: str,
  pub module: str,
  pub elem: u32,
  pub array_length: i64,
  pub span: diag.Span,

  pub fn write(self, a: *Ast, out: *std.io.BufWriter) {
    match self.kind {
      .Struct, .Enum => out.write(self.name),
      .Array => {
        if self.elem == 0 {
          out.write(self.kind.toString());
        } else {
          out.write("[");
          out.writeInt(self.array_length);
          out.write("]");
          a.types.at(self.elem).write(a, out);
        }
      },
      .Slice => {
        if self.elem == 0 {
          out.write(self.kind.toString());
        } else {
          out.write("[]");
          a.types.at(self.elem).write(a, out);
        }
      },
      .Optional => {
        if self.elem == 0 {
          out.write(self.kind.toString());
        } else {
          out.write("?");
          a.types.at(self.elem).write(a, out);
        }
      },
      .Pointer => {
        if self.elem == 0 {
          out.write(self.kind.toString());
        } else {
          out.write("*");
          a.types.at(self.elem).write(a, out);
        }
      },
      _ => out.write(self.kind.toString()),
    };
  }
}

pub enum BinaryOp{
  Add,
  Sub,
  Mul,
  Div,
  Rem,
  Eq,
  Ne,
  Lt,
  Le,
  Gt,
  Ge,
  And,
  Or,
  Bitand,
  Bitor,
  Bitxor,
  Shl,
  Shr,

  pub fn toString(self): str {
    return match self {
      .Add => "+",
      .Sub => "-",
      .Mul => "*",
      .Div => "/",
      .Rem => "%",
      .Eq => "=",
      .Ne => "!=",
      .Lt => "<",
      .Le => "<=",
      .Gt => ">",
      .Ge => ">=",
      .And => "&&",
      .Or => "||",
      .Bitand => "&",
      .Bitor => "|",
      .Bitxor => "^",
      .Shl => "<<",
      .Shr => ">>",
    };
  }

  pub fn toIr(self, is_signed: bool): str {
    return match self {
      .Add => "add",
      .Sub => "sub",
      .Mul => "mul",
      .Div => is_signed ? "sdiv" : "udiv",
      .Rem => is_signed ? "srem" : "urem",
      .Eq => "icmp eq",
      .Ne => "icmp ne",
      .Lt => is_signed ? "icmp slt" : "icmp ult",
      .Le => is_signed ? "icmp sle" : "icmp ule",
      .Gt => is_signed ? "icmp sgt" : "icmp ugt",
      .Ge => is_signed ? "icmp sge" : "icmp uge",
      .And, .Bitand => "and",
      .Or, .Bitor => "or",
      .Bitxor => "xor",
      .Shl => "shl",
      .Shr => is_signed ? "ashr" : "lshr",
    };
  }

  pub fn toIrFloat(self): str {
    return match self {
      .Add => "fadd",
      .Sub => "fsub",
      .Mul => "fmul",
      .Div => "fdiv",
      .Rem => "frem",
      .Eq => "fcmp oeq",
      .Ne => "fcmp une",
      .Lt => "fcmp olt",
      .Le => "fcmp ole",
      .Gt => "fcmp ogt",
      .Ge => "fcmp oge",
      _ => "?",
    };
  }

  pub fn isArithmetic(self): bool {
    return match self {
      .Add, .Sub, .Mul, .Div, .Rem => true,
      _ => false,
    };
  }

  pub fn isComparison(self): bool {
    return match self {
      .Eq, .Ne, .Lt, .Gt, .Le, .Ge => true,
      _ => false,
    };
  }

  pub fn isLogical(self): bool {
    return match self {
      .And, .Or => true,
      _ => false,
    };
  }
}

pub enum UnaryOp {
  Not,
  Neg,
  Addr,

  pub fn toString(self): str {
    return match self {
      .Not => "!",
      .Neg => "-",
      _ => "?",
    };
  }

  pub fn toIr(self): str {
    return match self {
      .Not => "xor",
      .Neg => "sub",
      _ => "?",
    };
  }
}

pub enum ExprKind {
  Boolean: bool,
  Number: str,
  String: str,
  Id: str,
  Call: CallExpr,
  Cast: CastExpr,
  Sizeof: Type,
  Binary: BinaryExpr,
  Unary: UnaryExpr,
  StructLiteral: StructLiteralExpr,
  Field: FieldExpr,
  EnumLiteral: EnumLiteralExpr,
  Array: Range,
  Index: IndexExpr,
  SliceRange: SliceRangeExpr,
  Match: MatchExpr,
  Null,
  Coalesce: PairExpr,
  Unwrap: u32,
  Propagate: u32,
  Ternary: TernaryExpr,
  Import: str,
  PostIncr: PostIncrExpr,
}

pub enum Visibility {
  Public,
  Private,

  pub fn toString(self): str {
    return match self {
      .Public => "pub",
      .Private => "priv",
    };
  }
}

fn printIndent(out: *std.io.BufWriter, depth: i32) {
  for i in 0..depth {
    out.write("  ");
  }
}

fn dumpBlock(a: *Ast, out: *std.io.BufWriter, body: Range, depth: i32) {
  let i: u32 = 0;
  while i < body.len {
    a.stmts.at(a.extra.get(body.start + i)).dump(a, out, depth + 1);
    i += 1;
  }
}

pub struct Expr {
  pub span: diag.Span,
  pub ty: Type,
  pub kind: ExprKind,

  pub fn init(span: diag.Span, kind: ExprKind): Expr {
    let e: Expr;
    e.span = span;
    e.kind = kind;
    return e;
  }

  pub fn dump(self, a: *Ast, out: *std.io.BufWriter, depth: i32) {
    printIndent(out, depth);
    match self.kind {
      .Boolean(b) => {
        out.write("Boolean literal ");
        out.writeln(b ? "true" : "false");
      },
      .Number(n) => {
        out.write("Number literal ");
        out.writeln(n);
      },
      .String(s) => {
        out.write("String literal \"");
        token.writeEscaped(out, s);
        out.writeln("\"");
      },
      .Id(name) => {
        out.write("Id ");
        out.writeln(name);
      },
      .Call(c) => {
        match a.exprs.at(c.callee).kind {
          .Field(f) => {
            out.write("MethodCall '");
            out.write(f.name);
            out.write("' (");
            out.writeInt(c.args.len as i64);
            out.writeln(" args)");
            a.exprs.at(f.base).dump(a, out, depth + 1);
          },
          .Id(name) => {
            out.write("Call '");
            out.write(name);
            out.write("' (");
            out.writeInt(c.args.len as i64);
            out.writeln(" args)");
          },
          _ => {},
        };

        let i: u32 = 0;
        while i < c.args.len {
          a.exprs.at(a.extra.get(c.args.start + i)).dump(a, out, depth + 1);
          i += 1;
        }
      },
      .Cast(c) => {
        out.write("Cast to ");
        out.writeln(c.target.kind.toString());
        a.exprs.at(c.operand).dump(a, out, depth + 1);
      },
      .Sizeof(t) => {
        out.write("Sizeof ");
        out.writeln(t.kind.toString());
      },
      .Binary(b) => {
        out.write("Binary ");
        out.writeln(b.op.toString());
        a.exprs.at(b.lhs).dump(a, out, depth + 1);
        a.exprs.at(b.rhs).dump(a, out, depth + 1);
      },
      .Unary(u) => {
        out.write("Unary ");
        out.writeln(u.op.toString());
        a.exprs.at(u.operand).dump(a, out, depth + 1);
      },
      .StructLiteral(s) => {
        out.write("StructLit '");
        out.write(s.type_name);
        out.writeln("'");
        let i: u32 = 0;
        while i < s.inits.len {
          const init = a.field_inits.at(a.extra.get(s.inits.start + i));
          printIndent(out, depth + 1);
          out.write("field ");
          out.writeln(init.name);
          a.exprs.at(init.value).dump(a, out, depth + 2);
          i += 1;
        }
      },
      .Field(f) => {
        out.write("Field ");
        out.writeln(f.name);
        a.exprs.at(f.base).dump(a, out, depth + 1);
      },
      .EnumLiteral(e) => {
        out.write("EnumLiteral .");
        out.writeln(e.name);
        if e.payload != 0 {
          a.exprs.at(e.payload).dump(a, out, depth + 1);
        }
      },
      .Array(r) => {
        out.write("Array (");
        out.writeInt(r.len as i64);
        out.writeln(" elements)");
        let i: u32 = 0;
        while i < r.len {
          a.exprs.at(a.extra.get(r.start + i)).dump(a, out, depth + 1);
          i += 1;
        }
      },
      .Index(x) => {
        out.writeln("Index");
        a.exprs.at(x.base).dump(a, out, depth + 1);
        a.exprs.at(x.index).dump(a, out, depth + 1);
      },
      .SliceRange(s) => {
        out.writeln("SliceRange");
        a.exprs.at(s.base).dump(a, out, depth + 1);
        a.exprs.at(s.start).dump(a, out, depth + 1);
        a.exprs.at(s.end).dump(a, out, depth + 1);
      },
      .Match(m) => {
        out.writeln("Match");
        a.exprs.at(m.scrutinee).dump(a, out, depth + 1);
        let i: u32 = 0;
        while i < m.arms.len {
          const arm = a.match_arms.at(a.extra.get(m.arms.start + i));
          printIndent(out, depth + 1);
          out.writeln(arm.pattern == 0 ? "Arm _" : "Arm");
          if arm.pattern != 0 {
            a.exprs.at(arm.pattern).dump(a, out, depth + 2);
          }
          if arm.binding.len > 0 {
            printIndent(out, depth + 2);
            out.write("bind ");
            out.writeln(arm.binding);
          }
          if arm.pattern_end != 0 {
            a.exprs.at(arm.pattern_end).dump(a, out, depth + 2);
          }
          if arm.value != 0 {
            a.exprs.at(arm.value).dump(a, out, depth + 2);
          }
          let j: u32 = 0;
          while j < arm.body.len {
            a.stmts.at(a.extra.get(arm.body.start + j)).dump(a, out, depth + 2);
            j += 1;
          }
          i += 1;
        }
      },
      .Null => out.writeln("Null"),
      .Coalesce(p) => {
        out.writeln("Coalesce");
        a.exprs.at(p.lhs).dump(a, out, depth + 1);
        a.exprs.at(p.rhs).dump(a, out, depth + 1);
      },
      .Unwrap(operand) => {
        out.writeln("Unwrap");
        a.exprs.at(operand).dump(a, out, depth + 1);
      },
      .Propagate(operand) => {
        out.writeln("Propagate");
        a.exprs.at(operand).dump(a, out, depth + 1);
      },
      .Ternary(t) => {
        out.writeln("Ternary");
        a.exprs.at(t.cond).dump(a, out, depth + 1);
        a.exprs.at(t.then).dump(a, out, depth + 1);
        a.exprs.at(t.els).dump(a, out, depth + 1);
      },
      .Import(path) => {
        out.write("Import \"");
        out.write(path);
        out.writeln("\"");
      },
      .PostIncr(p) => {
        out.write("PostIncr ");
        out.writeln(p.increment ? "++" : "--");
        a.exprs.at(p.operand).dump(a, out, depth + 1);
      },
    };
  }
}

pub struct Range {
  pub start: u32,
  pub len: u32,

  pub fn empty(): Range {
    return Range{start: 0, len: 0};
  }
}

pub struct BinaryExpr {
  pub op: BinaryOp,
  pub lhs: u32,
  pub rhs: u32,
}

pub struct UnaryExpr {
  pub op: UnaryOp,
  pub operand: u32,
}

pub struct PostIncrExpr {
  pub operand: u32,
  pub increment: bool,
}

pub struct CallExpr {
  pub callee: u32,
  pub args: Range,
  pub type_scoped: bool,
}

pub struct CastExpr {
  pub operand: u32,
  pub target: Type,
}

pub struct StructLiteralExpr{
  pub type_name: str,
  pub module: str,
  pub inits: Range,
}

pub struct FieldExpr {
  pub base: u32,
  pub name: str,
}

pub struct FieldInit {
  pub span: diag.Span,
  pub name: str,
  pub value: u32,
}

pub struct EnumLiteralExpr {
  pub name: str,
  pub payload: u32,
}

pub struct IndexExpr {
  pub base: u32,
  pub index: u32,
}

pub struct SliceRangeExpr {
  pub base: u32,
  pub start: u32,
  pub end: u32,
}

pub struct MatchExpr {
  pub scrutinee: u32,
  pub arms: Range,
}

pub struct MatchArm {
  pub span: diag.Span,
  pub pattern: u32,
  pub pattern_end: u32,
  pub binding: str,
  pub value: u32,
  pub body: Range,
  pub is_block: bool,
  pub or_next: bool,

  pub fn init(): MatchArm {
    let a: MatchArm;
    return a;
  }
}

pub struct PairExpr {
  pub lhs: u32,
  pub rhs: u32,
}

pub struct TernaryExpr {
  pub cond: u32,
  pub then: u32,
  pub els: u32,
}

pub struct IfStmt {
  pub cond: u32,
  pub then_body: Range,
  pub else_body: Range,
}

pub struct BindingStmt {
  pub name: str,
  pub ty: Type,
  pub mutable: bool,
  pub init: u32,
}

pub struct AssignStmt {
  pub target: u32,
  pub value: u32,
  pub compound: bool,
  pub coalesce: bool,
  pub op: BinaryOp,
}

pub struct WhileStmt {
  pub cond: u32,
  pub body: Range,
}

pub struct ForStmt {
  pub variable: str,
  pub start: u32,
  pub end: u32,
  pub iterable: u32,
  pub body: Range,
}

pub enum StmtKind {
  Return: u32,
  ExprStmt: u32,
  If: IfStmt,
  Binding: BindingStmt,
  Assign: AssignStmt,
  While: WhileStmt,
  For: ForStmt,
  Break,
  Continue,
  Defer: u32,
}

pub struct Stmt {
  pub span: diag.Span,
  pub kind: StmtKind,

  pub fn init(span: diag.Span, kind: StmtKind): Stmt {
    let s: Stmt;
    s.span = span;
    s.kind = kind;
    return s;
  }

  pub fn dump(self, a: *Ast, out: *std.io.BufWriter, depth: i32) {
    printIndent(out, depth);
    match self.kind {
      .Return(v) => {
        out.writeln("Return");
        if v != 0 {
          a.exprs.at(v).dump(a, out, depth + 1);
        }
      },
      .ExprStmt(v) => {
        out.writeln("ExprStmt");
        a.exprs.at(v).dump(a, out, depth + 1);
      },
      .If(s) => {
        out.writeln("If");
        a.exprs.at(s.cond).dump(a, out, depth + 1);
        printIndent(out, depth + 1);
        out.writeln("Then");
        dumpBlock(a, out, s.then_body, depth + 1);
        if s.else_body.len > 0 {
          printIndent(out, depth + 1);
          out.writeln("Else");
          dumpBlock(a, out, s.else_body, depth + 1);
        }
      },
      .Binding(b) => {
        out.write(b.mutable ? "Let " : "Const ");
        out.write(b.name);
        out.write(": ");
        b.ty.write(a, out);
        out.writeln("");
        if b.init != 0 {
          a.exprs.at(b.init).dump(a, out, depth + 1);
        }
      },
      .Assign(s) => {
        match a.exprs.at(s.target).kind {
          .Id(name) => {
            out.write("Assign ");
            out.writeln(name);
          },
          _ => {
            out.writeln("Assign");
            a.exprs.at(s.target).dump(a, out, depth + 1);
          },
        };
        a.exprs.at(s.value).dump(a, out, depth + 1);
      },
      .While(s) => {
        out.writeln("While");
        a.exprs.at(s.cond).dump(a, out, depth + 1);
        printIndent(out, depth + 1);
        out.writeln("Do");
        dumpBlock(a, out, s.body, depth + 1);
      },
      .For(s) => {
        out.write("For ");
        out.writeln(s.variable);
        printIndent(out, depth + 1);
        if s.iterable != 0 {
          out.writeln("Iter");
          a.exprs.at(s.iterable).dump(a, out, depth + 2);
        } else {
          out.writeln("Range");
          a.exprs.at(s.start).dump(a, out, depth + 2);
          a.exprs.at(s.end).dump(a, out, depth + 2);
        }
        printIndent(out, depth + 1);
        out.writeln("Do");
        dumpBlock(a, out, s.body, depth + 1);
      },
      .Break => out.writeln("Break"),
      .Continue => out.writeln("Continue"),
      .Defer(v) => {
        out.writeln("Defer");
        a.exprs.at(v).dump(a, out, depth + 1);
      },
    };
  }
}

pub struct Param {
  pub name: str,
  pub ty: Type,
  pub mutable: bool,
  pub is_self: bool,
  pub default_value: u32,

  pub fn init(): Param {
    let p: Param;
    p.mutable = true;
    return p;
  }
}

pub struct Field {
  pub span: diag.Span,
  pub name: str,
  pub ty: Type,
  pub default_value: u32,
  pub visibility: Visibility,

  pub fn init(): Field {
    let f: Field;
    return f;
  }
}

pub struct FnDecl {
  pub params: Range,
  pub return_type: Type,
  pub body: Range,
  pub is_extern: bool,
  pub variadic: bool,
}

pub struct GlobalDecl {
  pub ty: Type,
  pub mutable: bool,
  pub init: u32,
}

pub struct StructDecl {
  pub fields: Range,
  pub members: Range,
}

pub struct ImportDecl {
  pub alias: str,
  pub path: str,
  pub resolved: u32 = 0,
}

pub struct EnumMember {
  pub span: diag.Span,
  pub name: str,
  pub value: i64,
  pub payload: Type,
  pub has_payload: bool,

  pub fn init(): EnumMember {
    let m: EnumMember;
    return m;
  }
}

pub struct EnumDecl {
  pub members: Range,
  pub methods: Range,
  pub tagged: bool = false,
}

pub enum DeclKind {
  Fn: FnDecl,
  Container: Range,
  Global: GlobalDecl,
  Struct: StructDecl,
  Import: ImportDecl,
  Enum: EnumDecl,
}

pub struct Decl {
  pub span: diag.Span,
  pub visibility: Visibility,
  pub name: str,
  pub kind: DeclKind,

  pub fn init(span: diag.Span, visibility: Visibility, name: str, kind: DeclKind): Decl {
    let d: Decl;
    d.span = span;
    d.visibility = visibility;
    d.name = name;
    d.kind = kind;
    return d;
  }

  pub fn dump(self, a: *Ast, out: *std.io.BufWriter, depth: i32) {
    printIndent(out, depth);
    match self.kind {
      .Fn(f) => {
        if f.is_extern {
          out.write("ExternFn '");
          out.write(self.name);
          out.write("' -> ");
          f.return_type.write(a, out);
          out.writeln(f.variadic ? " (variadic)" : "");
        } else {
          out.write("FnDecl ");
          out.write(self.visibility.toString());
          out.write(" '");
          out.write(self.name.len > 0 ? self.name : "(anonymous)");
          out.write("' -> ");
          f.return_type.write(a, out);
          out.writeln("");
        }
        let i: u32 = 0;
        while i < f.params.len {
          const param = a.params.at(a.extra.get(f.params.start + i));
          printIndent(out, depth + 1);
          out.write("param ");
          out.write(param.mutable ? "" : "const ");
          out.write(param.name);
          out.write(": ");
          param.ty.write(a, out);
          out.writeln("");
          if param.default_value != 0 {
            a.exprs.at(param.default_value).dump(a, out, depth + 2);
          }
          i += 1;
        }
        if !f.is_extern {
          dumpBlock(a, out, f.body, depth);
        }
      },
      .Container(members) => {
        out.write("Container ");
        out.write(self.name.len > 0 ? self.name : "(file)");
        out.write(" (");
        out.writeInt(members.len as i64);
        out.writeln(" members)");
        let i: u32 = 0;
        while i < members.len {
          a.decls.at(a.extra.get(members.start + i)).dump(a, out, depth + 1);
          i += 1;
        }
      },
      .Struct(s) => {
        out.write("Struct ");
        out.write(self.visibility.toString());
        out.write(" '");
        out.write(self.name);
        out.writeln("'");
        let i: u32 = 0;
        while i < s.fields.len {
          const field = a.fields.at(a.extra.get(s.fields.start + i));
          printIndent(out, depth + 1);
          out.write("field ");
          out.write(field.name);
          out.write(": ");
          field.ty.write(a, out);
          out.writeln("");
          if field.default_value != 0 {
            a.exprs.at(field.default_value).dump(a, out, depth + 2);
          }
          i += 1;
        }
        let j: u32 = 0;
        while j < s.members.len {
          a.decls.at(a.extra.get(s.members.start + j)).dump(a, out, depth + 1);
          j += 1;
        }
      },
      .Enum(e) => {
        out.write("Enum ");
        out.write(self.visibility.toString());
        out.write(" '");
        out.write(self.name);
        out.writeln("'");
        let i: u32 = 0;
        while i < e.members.len {
          const member = a.enum_members.at(a.extra.get(e.members.start + i));
          printIndent(out, depth + 1);
          out.write("member ");
          out.write(member.name);
          out.write(" = ");
          out.writeInt(member.value);
          if member.has_payload {
            out.write(": ");
            member.payload.write(a, out);
          }
          out.writeln("");
          i += 1;
        }
        let j: u32 = 0;
        while j < e.methods.len {
          a.decls.at(a.extra.get(e.methods.start + j)).dump(a, out, depth + 1);
          j += 1;
        }
      },
      .Global(g) => {
        out.write("GlobalDecl ");
        out.write(self.visibility.toString());
        out.write(g.mutable ? " let '" : " const '");
        out.write(self.name);
        out.write("': ");
        g.ty.write(a, out);
        out.writeln("");
        if g.init != 0 {
          a.exprs.at(g.init).dump(a, out, depth + 1);
        }
      },
      .Import(im) => {
        out.write("Import '");
        out.write(im.alias);
        out.write("' \"");
        out.write(im.path);
        out.writeln("\"");
      },
    };
  }
}

// =============== Pools ===============
// TODO: Generics or marcros would make this much easier
// TODO: ModuleList also has same shape
pub struct ExprPool {
  arena: *std.mem.Arena,
  items: []Expr,
  pub len: i64,

  pub fn init(arena: *std.mem.Arena): ExprPool {
    let p: ExprPool;
    p.arena = arena;
    let e: Expr;
    p.push(e);
    return p;
  }

  pub fn push(self, expr: Expr): u32 {
    if self.len == self.items.len {
      const cap: i64 = self.items.len == 0 ? 8 : self.items.len * 2;
      let bigger = self.arena.alloc(cap * sizeof(Expr)) as []Expr;
      let i: i64 = 0;
      while i < self.len {
        bigger[i] = self.items[i];
        i += 1;
      }
      self.items = bigger;
    }

    self.items[self.len] = expr;
    self.len += 1;
    return (self.len - 1) as u32;
  }

  pub fn at(self, idx: u32): *Expr {
    return &self.items[idx as i64];
  }
}

