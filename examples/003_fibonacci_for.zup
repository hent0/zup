const std = import("std");

fn fib(n: i32) {
  if n <= 0 {
    return;
  }

  let a: i32 = 0;
  let b: i32 = 1;

  std.printf("%d ", a);

  if n > 1 {
    std.printf("%d ", b);
  }

  for i in 3..n + 1 {
    let current: i32 = a + b;
    std.printf("%d ", current);

    a = b;
    b = current;
  }

  std.printf("\n");
}

pub fn main(): i32 {
  fib(10);
  return 0;
}
