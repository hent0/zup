fn fib(n: i32) {
  if n <= 0 {
    return;
  }

  let a: i32 = 0;
  let b: i32 = 1;

  printf("%d ", a);

  if n > 1 {
    printf("%d ", b);
  }

  for i in 3..n + 1 {
    let current: i32 = a + b;
    printf("%d ", current);

    a = b;
    b = current;
  }

  printf("\n");
}

pub fn main(): i32 {
  fib(10);
  return 0;
}
