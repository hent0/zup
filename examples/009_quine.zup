const std = import("std");

pub fn main(): i32 {
  const s = "const std = import(%c%c%c%c%c);%c%cpub fn main(): i32 {%c  const s = %c%s%c;%c  std.io.printf(s, 34, 115, 116, 100, 34, 10, 10, 10, 34, s, 34, 10, 10, 10, 10);%c  return 0;%c}%c";
  std.io.printf(s, 34, 115, 116, 100, 34, 10, 10, 10, 34, s, 34, 10, 10, 10, 10);
  return 0;
}
