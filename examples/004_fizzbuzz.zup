const std = import("std");

extern printf(fmt: cstr, ...);

pub fn main(): i32 {
  let i: i32 = 1;

  while i <= 100 {
    if i % 3 == 0 && i % 5 == 0 {
        std.println("FizzBuzz");
    } else if i % 3 == 0 {
        std.println("Fizz");
    } else if i % 5 == 0 {
        std.println("Buzz");
    } else {
        printf("%d\n", i);
    }

    i = i + 1;
  }

  return 0;
}
